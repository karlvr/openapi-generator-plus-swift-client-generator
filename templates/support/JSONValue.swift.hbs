import Foundation

public enum JSONValue: Swift.Codable, Swift.Hashable, Swift.Sendable {
    case string(Swift.String)
    case number(Swift.Double)
    case int(Swift.Int)
    case boolean(Swift.Bool)
    case array([JSONValue])
    case object([Swift.String: JSONValue])
    case null

    // MARK: Decoding Logic
    public init(from decoder: Swift.Decoder) throws {
        let container = try decoder.singleValueContainer()

        if let stringValue = try? container.decode(Swift.String.self) {
            self = .string(stringValue)
        } else if let intValue = try? container.decode(Swift.Int.self) {    // decode int first to avoid decoding integers as doubles
            self = .int(intValue)
        } else if let numberValue = try? container.decode(Swift.Double.self) {
            self = .number(numberValue)
        } else if let booleanValue = try? container.decode(Swift.Bool.self) {
            self = .boolean(booleanValue)
        } else if let arrayValue = try? container.decode([JSONValue].self) {
            self = .array(arrayValue)
        } else if let objectValue = try? container.decode([Swift.String: JSONValue].self) {
            self = .object(objectValue)
        } else if container.decodeNil() {
            self = .null
        } else {
            throw Swift.DecodingError.dataCorruptedError(in: container, debugDescription: "Unknown JSON value")
        }
    }

    // MARK: Encoding Logic
    public func encode(to encoder: Swift.Encoder) throws {
        var container = encoder.singleValueContainer()

        switch self {
        case .string(let value):
            try container.encode(value)
        case .int(let value):
            try container.encode(value)
        case .number(let value):
            try container.encode(value)
        case .boolean(let value):
            try container.encode(value)
        case .array(let value):
            try container.encode(value)
        case .object(let value):
            try container.encode(value)
        case .null:
            try container.encodeNil()
        }
    }
}

// MARK: - Initializers for Common Types
